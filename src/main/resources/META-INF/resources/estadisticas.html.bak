<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sismógrafo Alerta · Panel Estadístico</title>
    <link rel="icon" href="data:,">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800;14..32,900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #08080e;
            color: #edf2f7;
            min-height: 100vh;
            line-height: 1.5;
        }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #0f0f18; }
        ::-webkit-scrollbar-thumb { background: rgba(245, 158, 11, 0.35); border-radius: 20px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(245, 158, 11, 0.6); }

        .glass-panel {
            background: rgba(18, 22, 33, 0.65);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 24px;
            box-shadow: 0 20px 48px -12px rgba(0, 0, 0, 0.8), inset 0 1px 0 rgba(255, 255, 255, 0.02);
        }

        .header-glass {
            background: rgba(10, 12, 22, 0.82);
            backdrop-filter: blur(24px) saturate(180%);
            -webkit-backdrop-filter: blur(24px) saturate(180%);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            padding: 14px 28px;
            position: sticky;
            top: 0;
            z-index: 50;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .brand-icon { font-size: 1.6rem; filter: drop-shadow(0 0 8px rgba(245, 158, 11, 0.2)); }
        .brand-title {
            font-size: 1.2rem;
            font-weight: 800;
            background: linear-gradient(145deg, #fbbf24, #f59e0b, #d97706);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: -0.02em;
        }
        .brand-badge {
            background: rgba(245, 158, 11, 0.08);
            border: 1px solid rgba(245, 158, 11, 0.12);
            color: #fbbf24;
            font-size: 0.55rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            padding: 2px 10px;
            border-radius: 100px;
            -webkit-text-fill-color: #fbbf24;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .btn-ghost {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            color: #cbd5e1;
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 500;
            transition: all 0.2s ease;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            backdrop-filter: blur(4px);
        }
        .btn-ghost:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(255, 255, 255, 0.08);
            color: #f1f5f9;
        }
        .btn-primary {
            background: rgba(245, 158, 11, 0.08);
            border: 1px solid rgba(245, 158, 11, 0.15);
            color: #fbbf24;
        }
        .btn-primary:hover {
            background: rgba(245, 158, 11, 0.15);
            border-color: rgba(245, 158, 11, 0.25);
            color: #fcd34d;
        }

        .main-container {
            max-width: 1360px;
            margin: 0 auto;
            padding: 20px 24px 28px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
        }
        .kpi-card {
            background: rgba(18, 22, 33, 0.55);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 20px;
            padding: 20px 22px;
            transition: all 0.2s ease;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
        }
        .kpi-card:hover {
            border-color: rgba(255, 255, 255, 0.06);
            transform: translateY(-2px);
            background: rgba(22, 26, 40, 0.65);
        }
        .kpi-label {
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: #7e8aa0;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .kpi-value {
            font-size: 2.1rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            margin-top: 6px;
            line-height: 1.1;
        }
        .kpi-sub {
            font-size: 0.7rem;
            color: #5f6b82;
            margin-top: 2px;
            font-weight: 400;
            letter-spacing: 0.01em;
        }
        .kpi-icon { font-size: 1.6rem; opacity: 0.5; }
        .value-blue { color: #60a5fa; }
        .value-amber { color: #fbbf24; }
        .value-red { color: #f87171; }
        .value-green { color: #4ade80; }

        .charts-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .chart-card {
            background: rgba(14, 18, 28, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 8px 28px -8px rgba(0, 0, 0, 0.5);
        }
        .chart-header {
            padding: 14px 20px;
            background: rgba(255, 255, 255, 0.01);
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .chart-header span:first-child {
            font-weight: 600;
            font-size: 0.75rem;
            letter-spacing: 0.02em;
            color: #d1d9e6;
        }
        .chart-header span:last-child {
            font-size: 0.6rem;
            font-weight: 400;
            color: #4f5b73;
        }
        .chart-container {
            height: 280px;
            padding: 8px 12px 4px;
            position: relative;
        }
        .chart-container canvas {
            width: 100% !important;
            height: 100% !important;
        }
        .full-width { grid-column: 1 / -1; }
        .pie-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 260px;
            padding: 8px;
        }
        .pie-wrapper canvas {
            max-width: 240px;
            max-height: 240px;
        }

        .historial-container {
            max-height: 400px;
            overflow-y: auto;
            padding: 12px 16px;
        }
        .historial-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            transition: all 0.2s ease;
            border-radius: 8px;
        }
        .historial-item:hover {
            background: rgba(255, 255, 255, 0.03);
        }
        .historial-item .magnitud {
            font-size: 1.1rem;
            font-weight: 700;
            min-width: 60px;
        }
        .historial-item .lugar {
            font-size: 0.8rem;
            color: #94a3b8;
            flex: 1;
            margin: 0 12px;
        }
        .historial-item .fecha {
            font-size: 0.65rem;
            color: #5f6b82;
            min-width: 120px;
            text-align: right;
        }
        .historial-item .critico { color: #f87171; }
        .historial-item .moderado { color: #4ade80; }
        .historial-item .pais-tag {
            font-size: 0.6rem;
            padding: 2px 8px;
            border-radius: 12px;
            font-weight: 600;
        }
        .pais-peru { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
        .pais-chile { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
        .pais-otros { background: rgba(148, 163, 184, 0.15); color: #94a3b8; }

        @media (max-width: 1024px) {
            .kpi-grid { grid-template-columns: repeat(2, 1fr); }
            .charts-grid { grid-template-columns: 1fr; }
            .header-glass { padding: 12px 18px; }
        }
        @media (max-width: 640px) {
            .kpi-grid { grid-template-columns: 1fr; }
            .header-glass { flex-direction: column; align-items: stretch; gap: 8px; }
            .brand { justify-content: center; }
            .header-actions { justify-content: center; flex-wrap: wrap; }
            .main-container { padding: 12px 12px 20px; gap: 14px; }
            .kpi-value { font-size: 1.7rem; }
            .chart-container { height: 210px; }
            .pie-wrapper { height: 220px; }
            .historial-item { flex-wrap: wrap; gap: 4px; }
            .historial-item .fecha { min-width: auto; text-align: left; }
        }
    </style>
</head>
<body>

<header class="header-glass">
    <div class="brand">
        <span class="brand-icon">📡</span>
        <span class="brand-title">Sismógrafo Alerta · Estadísticas</span>
        <span class="brand-badge">análisis en tiempo real</span>
    </div>
    <div class="header-actions">
        <a href="/index.html" class="btn-ghost">🗺️ Mapa</a>
        <button onclick="cargarDatosEstadisticos()" class="btn-ghost btn-primary">⟳ Actualizar</button>
        <span class="text-[0.55rem] font-medium text-slate-500 bg-white/5 px-3 py-1 rounded-full border border-white/5 hidden sm:inline-flex">
            <span id="last-update-label">actualizando…</span>
        </span>
    </div>
</header>

<main class="main-container">
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="flex justify-between items-start">
                <div>
                    <div class="kpi-label"><span>🌐</span> Total eventos</div>
                    <div class="kpi-value value-blue" id="kpi-total">0</div>
                    <div class="kpi-sub">IGP + USGS</div>
                </div>
                <span class="kpi-icon">📋</span>
            </div>
        </div>
        <div class="kpi-card">
            <div class="flex justify-between items-start">
                <div>
                    <div class="kpi-label"><span>🇵🇪</span> Sismos Perú</div>
                    <div class="kpi-value value-red" id="kpi-peru">0</div>
                    <div class="kpi-sub">IGP</div>
                </div>
                <span class="kpi-icon">📊</span>
            </div>
        </div>
        <div class="kpi-card">
            <div class="flex justify-between items-start">
                <div>
                    <div class="kpi-label"><span>🌍</span> Otros países</div>
                    <div class="kpi-value value-amber" id="kpi-otros">0</div>
                    <div class="kpi-sub" id="kpi-otros-conteo">USGS</div>
                </div>
                <span class="kpi-icon">🌎</span>
            </div>
        </div>
        <div class="kpi-card">
            <div class="flex justify-between items-start">
                <div>
                    <div class="kpi-label"><span>📊</span> Magnitud promedio</div>
                    <div class="kpi-value value-green" id="kpi-promedio">M 0.0</div>
                    <div class="kpi-sub">rango histórico</div>
                </div>
                <span class="kpi-icon">📈</span>
            </div>
        </div>
    </div>

    <div class="charts-grid">
        <div class="chart-card">
            <div class="chart-header">
                <span>📉 Tendencia de magnitudes</span>
                <span id="chart-lineas-count">0 eventos</span>
            </div>
            <div class="chart-container">
                <canvas id="chartLineas"></canvas>
            </div>
        </div>

        <div class="chart-card">
            <div class="chart-header">
                <span>🏔️ Actividad por región</span>
                <span>distribución geográfica</span>
            </div>
            <div class="chart-container">
                <canvas id="chartBarras"></canvas>
            </div>
        </div>

        <div class="chart-card full-width">
            <div class="chart-header">
                <span>🧩 Severidad de eventos</span>
                <span>moderados vs críticos</span>
            </div>
            <div class="pie-wrapper">
                <canvas id="chartPastel"></canvas>
            </div>
        </div>

        <div class="chart-card full-width">
            <div class="chart-header">
                <span>📋 Historial completo de sismos</span>
                <span id="historial-count">0 eventos</span>
            </div>
            <div class="historial-container" id="historialLista">
                <div class="text-center text-slate-500 py-8 text-sm">Cargando datos...</div>
            </div>
        </div>
    </div>
</main>

<script>
    const BACKEND_URL = "https://supervisors-feat-quotations-talking.trycloudflare.com";

    let chartLineas = null;
    let chartBarras = null;
    let chartPastel = null;

    // 🔥 MISMA LÓGICA QUE EL INDEX.HTML
    function obtenerInfoPais(lugar, sismo) {
        if (!lugar) return { categoria: "otros", nombre: "Otros", emoji: "🌍", flag: "🏳️", color: "#64748b" };

        const lugarLower = lugar.toLowerCase();

        // 1️⃣ PRIORIDAD: Si tiene usgsId que empieza con "IGP_" o "2026-" → PERÚ
        if (sismo && sismo.usgsId) {
            if (sismo.usgsId.startsWith("IGP_") || sismo.usgsId.startsWith("2026-")) {
                return { categoria: "peru", nombre: "Perú", emoji: "🇵🇪", flag: "🇵🇪", color: "#ef4444" };
            }
        }

        // 2️⃣ Si el lugar contiene "peru" o "arequipa" o "igp" → PERÚ
        if (lugarLower.includes("peru") || lugarLower.includes("arequipa") || lugarLower.includes("igp")) {
            return { categoria: "peru", nombre: "Perú", emoji: "🇵🇪", flag: "🇵🇪", color: "#ef4444" };
        }

        // 3️⃣ Si contiene "chile" → CHILE
        if (lugarLower.includes("chile")) {
            return { categoria: "chile", nombre: "Chile", emoji: "🇨🇱", flag: "🇨🇱", color: "#3b82f6" };
        }

        // 4️⃣ Todo lo demás → OTROS
        return { categoria: "otros", nombre: "Otros", emoji: "🌍", flag: "🏳️", color: "#64748b" };
    }

    function categoriaPais(lugar, sismo) {
        return obtenerInfoPais(lugar, sismo).categoria;
    }

    function promedio(arr) {
        if (!arr || arr.length === 0) return 0;
        return arr.reduce((a, b) => a + b, 0) / arr.length;
    }

    async function cargarDatosEstadisticos() {
        try {
            const resp = await fetch(`${BACKEND_URL}/api/sismos`, {
                headers: { 'ngrok-skip-browser-warning': 'true' }
            });

            if (resp.status === 204) {
                resetearDashboard();
                document.getElementById('last-update-label').innerText = 'sin datos';
                return;
            }

            const sismos = await resp.json();

            console.log("📊 TOTAL DE SISMOS RECIBIDOS:", sismos.length);

            let datosSismos = sismos;
            if (sismos && typeof sismos === 'object' && !Array.isArray(sismos)) {
                if (sismos.data && Array.isArray(sismos.data)) {
                    datosSismos = sismos.data;
                } else if (sismos.features && Array.isArray(sismos.features)) {
                    datosSismos = sismos.features.map(f => ({
                        magnitud: f.properties.mag || 0,
                        lugar: f.properties.place || 'Desconocido',
                        fechaHora: f.properties.time ? new Date(f.properties.time).toISOString() : new Date().toISOString(),
                        alertaCritica: (f.properties.mag || 0) >= 5.5,
                        usgsId: f.id || null
                    }));
                } else {
                    const values = Object.values(sismos);
                    if (values.length > 0 && Array.isArray(values[0])) {
                        datosSismos = values[0];
                    } else {
                        datosSismos = [sismos];
                    }
                }
            }

            if (!datosSismos || datosSismos.length === 0) {
                resetearDashboard();
                document.getElementById('last-update-label').innerText = 'sin eventos';
                return;
            }

            const total = datosSismos.length;
            let maxSismo = datosSismos[0];
            let criticos = 0;
            let sumaMag = 0;
            let peruCount = 0;
            let chileCount = 0;
            let otrosCount = 0;

            const conteoPaises = { "Perú 🇵🇪": 0, "Chile 🇨🇱": 0, "Otros Países 🌍": 0 };
            const etiquetasTiempo = [];
            const valoresMag = [];

            const ordenados = [...datosSismos].sort((a, b) => new Date(b.fechaHora) - new Date(a.fechaHora));

            ordenados.forEach(s => {
                const mag = typeof s.magnitud === 'number' ? s.magnitud : parseFloat(s.magnitud) || 0;

                if (mag > (maxSismo.magnitud || 0)) {
                    maxSismo = s;
                }
                if (s.alertaCritica || mag >= 5.5) {
                    criticos++;
                }
                sumaMag += mag;

                // 🔥 USAR LA MISMA LÓGICA QUE EL INDEX
                const infoPais = obtenerInfoPais(s.lugar, s);
                const paisKey = infoPais.categoria === 'peru' ? "Perú 🇵🇪" :
                    infoPais.categoria === 'chile' ? "Chile 🇨🇱" : "Otros Países 🌍";
                conteoPaises[paisKey] = (conteoPaises[paisKey] || 0) + 1;

                if (infoPais.categoria === 'peru') peruCount++;
                else if (infoPais.categoria === 'chile') chileCount++;
                else otrosCount++;

                const fecha = new Date(s.fechaHora);
                const label = fecha.toLocaleDateString() + ' ' + fecha.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                etiquetasTiempo.push(label);
                valoresMag.push(mag);
            });

            console.log(`📊 Perú: ${peruCount}, Chile: ${chileCount}, Otros: ${otrosCount}`);

            const prom = total > 0 ? sumaMag / total : 0;
            const pctCriticos = total > 0 ? ((criticos / total) * 100).toFixed(1) : "0.0";

            document.getElementById('kpi-total').innerText = total;
            document.getElementById('kpi-peru').innerText = peruCount;
            document.getElementById('kpi-otros').innerText = otrosCount;
            document.getElementById('kpi-otros-conteo').innerText = `${otrosCount} sismos de USGS`;
            document.getElementById('kpi-promedio').innerText = `M ${prom.toFixed(1)}`;

            document.getElementById('chart-lineas-count').innerText = `${total} eventos`;
            document.getElementById('historial-count').innerText = `${total} eventos`;

            const gridOpts = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(12,14,24,0.92)',
                        borderColor: 'rgba(255,255,255,0.04)',
                        borderWidth: 1,
                        titleColor: '#f1f5f9',
                        bodyColor: '#9aa6bf',
                        cornerRadius: 10,
                        padding: 10,
                    }
                },
                scales: {
                    x: {
                        grid: { color: 'rgba(255,255,255,0.02)' },
                        ticks: { color: '#5f6b82', font: { size: 9, weight: '400' }, maxTicksLimit: 20 }
                    },
                    y: {
                        grid: { color: 'rgba(255,255,255,0.02)' },
                        ticks: { color: '#5f6b82', font: { size: 9, weight: '400' } }
                    }
                }
            };

            if (chartLineas) chartLineas.destroy();
            const ctxLineas = document.getElementById('chartLineas').getContext('2d');
            chartLineas = new Chart(ctxLineas, {
                type: 'line',
                data: {
                    labels: etiquetasTiempo,
                    datasets: [{
                        label: 'Magnitud',
                        data: valoresMag,
                        borderColor: '#60a5fa',
                        backgroundColor: (ctx) => {
                            const grad = ctx.chart.ctx.createLinearGradient(0, 0, 0, 280);
                            grad.addColorStop(0, 'rgba(96, 165, 250, 0.18)');
                            grad.addColorStop(1, 'rgba(96, 165, 250, 0.01)');
                            return grad;
                        },
                        borderWidth: 2.5,
                        tension: 0.35,
                        fill: true,
                        pointBackgroundColor: '#93bbfc',
                        pointBorderColor: '#1e3a6b',
                        pointBorderWidth: 1.2,
                        pointRadius: 3.5,
                        pointHoverRadius: 7,
                    }]
                },
                options: { ...gridOpts, plugins: { ...gridOpts.plugins, legend: { display: false } } }
            });

            if (chartBarras) chartBarras.destroy();
            const ctxBarras = document.getElementById('chartBarras').getContext('2d');
            const labelsBarras = Object.keys(conteoPaises);
            const dataBarras = Object.values(conteoPaises);

            const coloresBarras = {
                "Perú 🇵🇪": 'rgba(239, 68, 68, 0.8)',
                "Chile 🇨🇱": 'rgba(59, 130, 246, 0.8)',
                "Otros Países 🌍": 'rgba(148, 163, 184, 0.8)'
            };

            chartBarras = new Chart(ctxBarras, {
                type: 'bar',
                data: {
                    labels: labelsBarras,
                    datasets: [{
                        data: dataBarras,
                        backgroundColor: labelsBarras.map(l => coloresBarras[l] || 'rgba(148, 163, 184, 0.8)'),
                        borderColor: labelsBarras.map(l => coloresBarras[l]?.replace('0.8', '1') || '#94a3b8'),
                        borderWidth: 2,
                        borderRadius: 8,
                    }]
                },
                options: {
                    ...gridOpts,
                    plugins: {
                        ...gridOpts.plugins,
                        legend: { display: false },
                        tooltip: {
                            ...gridOpts.plugins.tooltip,
                            callbacks: { label: function(context) { return context.parsed.y + ' sismos'; } }
                        }
                    },
                    scales: {
                        ...gridOpts.scales,
                        y: { ...gridOpts.scales.y, beginAtZero: true, ticks: { ...gridOpts.scales.y.ticks, stepSize: 10 } }
                    }
                }
            });

            if (chartPastel) chartPastel.destroy();
            const ctxPastel = document.getElementById('chartPastel').getContext('2d');
            chartPastel = new Chart(ctxPastel, {
                type: 'pie',
                data: {
                    labels: ['Moderados (< 5.5)', 'Críticos (≥ 5.5)'],
                    datasets: [{
                        data: [total - criticos, criticos],
                        backgroundColor: ['rgba(74, 222, 128, 0.75)', 'rgba(248, 113, 113, 0.8)'],
                        borderColor: ['#4ade80', '#f87171'],
                        borderWidth: 2,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                color: '#b6c2d9',
                                font: { size: 11, weight: '500' },
                                padding: 16,
                                usePointStyle: true,
                                pointStyle: 'circle'
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(12,14,24,0.92)',
                            borderColor: 'rgba(255,255,255,0.04)',
                            borderWidth: 1,
                            titleColor: '#f1f5f9',
                            bodyColor: '#9aa6bf',
                            cornerRadius: 10,
                            padding: 10,
                            callbacks: {
                                label: function(ctx) {
                                    const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                                    const pct = ((ctx.parsed / total) * 100).toFixed(1);
                                    return ctx.label + ': ' + ctx.parsed + ' (' + pct + '%)';
                                }
                            }
                        }
                    }
                }
            });

            const historialContainer = document.getElementById('historialLista');
            historialContainer.innerHTML = '';

            ordenados.forEach(s => {
                const mag = typeof s.magnitud === 'number' ? s.magnitud : parseFloat(s.magnitud) || 0;
                const fecha = new Date(s.fechaHora);
                const fechaStr = fecha.toLocaleDateString() + ' ' + fecha.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                const esCritico = s.alertaCritica || mag >= 5.5;
                const infoPais = obtenerInfoPais(s.lugar, s);
                const esPeru = infoPais.categoria === 'peru';
                const esChile = infoPais.categoria === 'chile';
                const paisClass = esPeru ? 'pais-peru' : (esChile ? 'pais-chile' : 'pais-otros');
                const paisLabel = esPeru ? '🇵🇪 Perú' : (esChile ? '🇨🇱 Chile' : '🌍 Otros');

                const item = document.createElement('div');
                item.className = 'historial-item';
                item.innerHTML = `
                    <span class="magnitud ${esCritico ? 'critico' : 'moderado'}">M ${mag.toFixed(1)}</span>
                    <span class="lugar">${s.lugar || 'Ubicación desconocida'}</span>
                    <span class="pais-tag ${paisClass}">${paisLabel}</span>
                    <span class="fecha">${fechaStr}</span>
                    ${esCritico ? '<span class="text-red-500 text-xs font-bold">🚨 CRÍTICO</span>' : ''}
                `;
                historialContainer.appendChild(item);
            });

            document.getElementById('last-update-label').innerText = new Date().toLocaleTimeString();

        } catch (error) {
            console.error('Error al cargar datos sismológicos:', error);
            resetearDashboard();
            document.getElementById('last-update-label').innerText = 'error';
        }
    }

    function resetearDashboard() {
        document.getElementById('kpi-total').innerText = '0';
        document.getElementById('kpi-peru').innerText = '0';
        document.getElementById('kpi-otros').innerText = '0';
        document.getElementById('kpi-otros-conteo').innerText = '0 sismos de USGS';
        document.getElementById('kpi-promedio').innerText = 'M 0.0';
        document.getElementById('historialLista').innerHTML = '<div class="text-center text-slate-500 py-8 text-sm">No hay datos</div>';

        if (chartLineas) { chartLineas.destroy(); chartLineas = null; }
        if (chartBarras) { chartBarras.destroy(); chartBarras = null; }
        if (chartPastel) { chartPastel.destroy(); chartPastel = null; }
    }

    let refreshInterval = null;
    function iniciarAutoRefresh() {
        if (refreshInterval) clearInterval(refreshInterval);
        refreshInterval = setInterval(cargarDatosEstadisticos, 30000);
    }

    window.addEventListener('load', () => {
        cargarDatosEstadisticos();
        iniciarAutoRefresh();
    });
</script>
</body>
</html>
